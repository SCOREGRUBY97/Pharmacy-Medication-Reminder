# ============================================================
# MediCare Medication Reminder System — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ── Backend Server ───────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL Database ──────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pharmacy_reminder
DB_USER=postgres
DB_PASSWORD=your_password_here

# ── JWT Authentication ────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_string
JWT_EXPIRES_IN=7d

# ── Email (Gmail SMTP) ────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM="MediCare Reminder <your_email@gmail.com>"

# ── Frontend URL (for CORS) ───────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── React Frontend (prefix with REACT_APP_) ───────────────────
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_APP_NAME=MediCare Reminder

# ── OpenAI AI Assistant (optional — demo mode works without key) ──
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini

# OpenAI API for AI medication assistant
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
